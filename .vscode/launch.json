    "version": "0.2.0",
    "configurations": [
    {
        "name": "Launch Chrome",
        "request": "launch",
        "type": "chrome",
        "url": "http://localhost:8080",
        "webRoot": "${workspaceFolder}"
    },
        {
            "name": "progress_flow",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=GOOGLE_IOS_CLIENT_ID=499907083503-0mcebgldos9mj57tvq3ff69o4l1qnudc.apps.googleusercontent.com",
                "--dart-define=GOOGLE_IOS_WEB_CLIENT_ID=499907083503-ur65p9us5uspbs58r2i86usn852q8g09.apps.googleusercontent.com"
            ]
        },
        {
            "name": "progress_flow (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "progress_flow (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}